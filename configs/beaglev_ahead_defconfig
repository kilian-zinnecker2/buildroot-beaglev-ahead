BR2_TARGET_GENERIC_ISSUE="Welcome to the BeagleV-Ahead"
BR2_ROOTFS_POST_IMAGE_SCRIPT="board/beaglev-ahead/post-image.sh"
BR2_LINUX_KERNEL=y

BR2_LINUX_KERNEL_CUSTOM_VERSION=y
